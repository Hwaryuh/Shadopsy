{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0",
        "composite": true,
        "paths": {
            "shared/*": ["src/shared/*"]
        },
        "baseUrl": "."
    },
    "include": ["src/client/**/*", "src/shared/**/*"]
}