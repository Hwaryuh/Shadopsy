{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": true,
        "outDir": "dist",
        "rootDir": "src",
        "skipLibCheck": true,
        "types": [
            "node"
        ],
        "ignoreDeprecations": "6.0"
    },
    "include": [
        "src/server/**/*",
        "src/shared/**/*"
    ],
    "exclude": [
        "node_modules",
        "src/client/**/*"
    ]
}